# =============================================================================
# ECK-WEB – Umgebungsvariablen
# =============================================================================
# Kopiere diese Datei nach .env.local für die lokale Entwicklung.
# Setze alle Pflichtfelder. Optionale Felder können leer bleiben.
# NIEMALS echte Werte in diese Datei committen.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_URL="https://www.ecksolution-it.de"

# Google Analytics – leer lassen, um Tracking vollständig zu deaktivieren
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# -----------------------------------------------------------------------------
# Admin-Authentifizierung (PFLICHT – mindestens eine Option konfigurieren)
# -----------------------------------------------------------------------------

# SESSION_SECRET: Wird für die HMAC-Signatur der Session-Cookies verwendet.
# Mindestens 32 zufällige Zeichen. In Produktion IMMER setzen.
# Generieren: openssl rand -hex 32
SESSION_SECRET="AENDERN_VOR_PRODUKTIONSEINSATZ_MINDESTENS_32_ZEICHEN"

# Option A – Einzelner Admin-Benutzer (empfohlen für Produktion)
# ADMIN_USERNAME: E-Mail-Adresse des Admins
# ADMIN_PASSWORD_HASH: bcrypt-Hash des Passworts (Cost-Factor 12)
# Generieren: node -e "require('bcryptjs').hash('IhrPasswort', 12).then(console.log)"
ADMIN_USERNAME="admin@ecksolution-it.de"
# ADMIN_PASSWORD_HASH="$2b$12$REPLACE_WITH_BCRYPT_HASH_OF_YOUR_PASSWORD"
ADMIN_PASSWORD_HASH="$argon2id$v=19$m=4096,t=3,p=1$c29tZXNhbHQ$qLml5cbqFAO6YxVHh"

# Option B – Mehrere Benutzer (JSON-Array mit bcrypt-Hashes)
# passwordHash: bcrypt-Hash des Passworts (KEIN Klartext!)
# Rollen: super_admin | admin | content_manager | editor | sales_campaign_manager | seo_analyst | partner
# ADMIN_DUMMY_USERS_JSON='[{"email":"admin@example.com","passwordHash":"$2b$12$...","role":"super_admin"}]'

# Bootstrap-Token (optional, für Erstzugang ohne Passwort)
# IAM_BOOTSTRAP_ROLE_MAP: JSON-Map email → Rolle
IAM_BOOTSTRAP_ROLE_MAP='{"admin@ecksolution-it.de":"super_admin"}'
# ADMIN_BOOTSTRAP_TOKEN: Einmal-Token für Bootstrap-Login (mindestens 32 Zeichen)
# Generieren: openssl rand -hex 32
ADMIN_BOOTSTRAP_TOKEN="CHANGE_ME_TO_RANDOM_SECRET"

# Nur für lokale Entwicklung: Auth vollständig deaktivieren
# NIEMALS in Produktion auf "true" setzen!
ADMIN_AUTH_DISABLED="false"
ADMIN_AUTH_DISABLED_EMAIL="admin-disabled@local"

# Header-Fallback für lokale Entwicklung (NIEMALS in Produktion aktivieren)
IAM_ALLOW_ROLE_HEADER="false"

# -----------------------------------------------------------------------------
# E-Mail / SMTP (für Kontaktformular)
# -----------------------------------------------------------------------------
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="info@ecksolution-it.de"
SMTP_PASS="IHR_SMTP_PASSWORT"
CONTACT_TO_EMAIL="info@ecksolution-it.de"

# -----------------------------------------------------------------------------
# Sentry – Fehler-Tracking (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN="https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX"
SENTRY_DSN="https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="eck-web"
SENTRY_AUTH_TOKEN="sntrys_XXXXXXXXXXXXXX"

# -----------------------------------------------------------------------------
# Ops / Persistenz
# -----------------------------------------------------------------------------
OPS_PERSISTENCE_MODE="memory"
OPS_DATA_DIR=".ops-data"

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
ADMIN_RATE_LIMIT_PER_MINUTE="120"
FORMS_RATE_LIMIT_PER_MINUTE="30"

# -----------------------------------------------------------------------------
# DSGVO / Datenhaltung
# -----------------------------------------------------------------------------
# Aufbewahrungszeitraum für Audit-Einträge mit personenbezogenen Daten
PII_RETENTION_DAYS="365"

# -----------------------------------------------------------------------------
# KI (optional)
# -----------------------------------------------------------------------------
GEMINI_API_KEY="IHR_GEMINI_API_KEY"
